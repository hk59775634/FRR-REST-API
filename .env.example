# API 认证密钥（请在生产环境中修改）
API_KEY=frr-rest-api-dev-key-change-me

# 服务监听地址与端口
HOST=0.0.0.0
PORT=8080

# frr-reload.py 路径
FRR_RELOAD_SCRIPT=/usr/lib/frr/frr-reload.py

# FRR 相关路径
FRR_CONF_PATH=/etc/frr/frr.conf
FRR_BINDIR=/usr/bin
FRR_CONF_DIR=/etc/frr
FRR_RUN_DIR=/var/run/frr
FRR_DAEMONS_PATH=/etc/frr/daemons
